#!/bin/sh
set -e

staged_non_version_files="$(git diff --cached --name-only --diff-filter=ACMR | grep -v -E '^(package\.json|package-lock\.json)$' || true)"

if [ -z "$staged_non_version_files" ]; then
  echo "No staged app changes to version; skipping automatic bump."
  exit 0
fi

node scripts/bump-version.mjs
git add package.json
git add package-lock.json
